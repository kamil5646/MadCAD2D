{
  "name": "madcad-2d-desktop",
  "version": "1.4.2",
  "description": "Desktopowa aplikacja CAD 2D MadCAD 2D, dla konstrukcji stalowych.",
  "main": "electron/main.js",
  "author": "Kamil Kasprzak",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "npm run serve & env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "serve": "vite",
    "build:ui": "vite build",
    "start": "npm run build:ui && env -u ELECTRON_RUN_AS_NODE electron .",
    "dist": "npm run build:ui && electron-builder --mac dir --win nsis --x64",
    "dist:mac": "npm run build:ui && electron-builder --mac dir",
    "dist:mac:trusted": "npm run build:ui && electron-builder --mac zip --arm64 --publish never",
    "dist:win:trusted": "npm run build:ui && electron-builder --win nsis --x64 --publish never",
    "dist:release:trusted": "npm run dist:mac:trusted && npm run dist:win:trusted",
    "dist:win": "npm run build:ui && electron-builder --win nsis --x64",
    "dist:dir": "npm run build:ui && electron-builder --dir"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "pl.kamilkasprzak.madcad2d",
    "productName": "MadCAD 2D",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "LICENSE",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "tools/oda",
        "to": "tools/oda",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "assets/icons/madcad.icns",
      "category": "public.app-category.graphics-design",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/madcad.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "afterSign": "scripts/notarize.js"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
