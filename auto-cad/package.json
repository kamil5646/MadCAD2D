{
  "name": "madcad-2d-desktop",
  "version": "1.0.0",
  "description": "Desktopowa aplikacja CAD 2D MadCAD 2D, dla konstrukcji stalowych.",
  "main": "electron/main.js",
  "author": "Kamil Kasprzak",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder --mac dir --win nsis --x64",
    "dist:mac": "electron-builder --mac dir",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "pl.kamilkasprzak.madcad2d",
    "productName": "MadCAD 2D",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "LICENSE",
      "LICENSE",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "assets/icons/madcad.icns",
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/madcad.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
