{
  "name": "madcad-2d-desktop",
  "version": "3.1.1",
  "description": "Desktopowa aplikacja CAD 2D MadCAD 2D, dla konstrukcji stalowych.",
  "main": "electron/main.js",
  "author": "Kamil Kasprzak",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder --mac dir --win nsis --x64",
    "dist:mac": "electron-builder --mac dir",
    "dist:mac:trusted": "electron-builder --mac zip --arm64 --publish never",
    "dist:win:trusted": "electron-builder --win nsis --x64 --publish never",
    "dist:release:trusted": "npm run dist:mac:trusted && npm run dist:win:trusted",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "pl.kamilkasprzak.madcad2d",
    "productName": "MadCAD 2D",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "LICENSE",
      "LICENSE",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "tools/oda",
        "to": "tools/oda",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "assets/icons/madcad.icns",
      "category": "public.app-category.graphics-design",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/madcad.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "afterSign": "scripts/notarize.js"
  }
}
